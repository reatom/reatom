{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "${configDir}/build",
    "tsBuildInfoFile": "${configDir}/build/.tsbuildinfo",
    "composite": true
  },
  "include": ["${configDir}/src"],
  "exclude": [
    "${configDir}/**/*.test.ts", 
    "${configDir}/**/*.test.browser.ts", 
    "${configDir}/**/*.test-d.ts", 
    "${configDir}/src/test.ts",
    "${configDir}/**/*.test.tsx", 
    "${configDir}/**/*.bench.ts",
  ]
}
