{
  "name": "reatom-workspace",
  "scripts": {
    "release": "npx tsx ./tools/publish.ts",
    "postinstall": "cd packages/core && npm run build",
    "reset": "sh ./tools/reset.sh",
    "test": "vitest run packages/core",
    "prettify": "prettier --write */**/**/*.{js,ts,md}",
    "prettify:check": "prettier --check */**/**/*.{js,ts,md}",
    "prettify:watch": "onchange */**/**/*.{js,ts,md} -- prettier --write {{changed}}",
    "package-generator": "tsx tools/new-package.ts",
    "update": "npx npm-check-updates -u",
    "prepare": "git config blame.ignoreRevsFile .git-blame-ignore-revs && husky",
    "actualize-issue-templates": "npx tsx ./tools/actualize-issue-templates.ts"
  },
  "workspaces": [
    "./packages/*"
  ],
  "packageManager": "npm@10.0.0",
  "engines": {
    "npm": ">=10"
  },
  "dependencies": {
    "@commitlint/cli": "^19.2.1",
    "@commitlint/config-conventional": "^19.1.0",
    "@types/node": "latest",
    "husky": "^9.1.7",
    "prettier": "^3.5.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8",
    "yoctobundle": "latest",
    "zx": "^8.3.2"
  },
  "author": "artalar",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/artalar/reatom.git"
  },
  "bugs": {
    "url": "https://github.com/artalar/reatom/issues"
  },
  "homepage": "https://www.reatom.dev",
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0"
  }
}
