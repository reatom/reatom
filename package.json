{
  "name": "reatom-workspace",
  "type": "module",
  "scripts": {
    "actualize-issue-templates": "tsx ./tools/actualize-issue-templates.ts",
    "build": "tsx ./tools/build.ts",
    "package-generator": "tsx tools/new-package.ts",
    "postinstall": "pnpm run build",
    "prepare": "git config blame.ignoreRevsFile .git-blame-ignore-revs && husky",
    "prettify:check": "prettier --check */**/**/*.{js,ts,md}",
    "prettify:watch": "onchange */**/**/*.{js,ts,md} -- prettier --write {{changed}}",
    "prettify": "prettier --write */**/**/*.{js,ts,md}",
    "release": "tsx ./tools/publish.ts",
    "reset": "sh ./tools/reset.sh",
    "test": "vitest run",
    "update": "npx npm-check-updates -u"
  },
  "packageManager": "pnpm@10.12.1",
  "workspaces": [
    "./packages/*"
  ],
  "dependencies": {
    "@commitlint/cli": "catalog:",
    "@commitlint/config-conventional": "catalog:",
    "@types/node": "catalog:",
    "husky": "catalog:",
    "prettier": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "yoctobundle": "catalog:",
    "zx": "catalog:"
  },
  "author": "artalar",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/artalar/reatom.git"
  },
  "bugs": {
    "url": "https://github.com/artalar/reatom/issues"
  },
  "homepage": "https://www.reatom.dev",
  "devDependencies": {
    "release-please": "^17.0.0"
  }
}
