---
// Hero Section Component

import { resolveBase } from './resolve-base'
---

<!-- Hero Section -->
<main class="hero-section" role="main">
  <!-- Animated Background Elements -->
  <div class="background-container">
    <div class="logo-shape">
      <svg
        viewBox="0 0 400 400"
        xmlns="http://www.w3.org/2000/svg"
        fill="#151134"
        stroke="#fff"
        stroke-width="1px"
      >
        <circle cx="200" cy="200" r="200" fill="#fff" stroke-width="0"
        ></circle>
        <circle cx="200" cy="200" r="199" stroke-width="0"></circle>
        <circle cx="180" cy="180" r="130"></circle>
        <circle cx="215" cy="180" r="70"></circle>
        <circle cx="150" cy="94" r="38"></circle>
        <circle cx="100" cy="195" r="40"></circle>
        <circle cx="165" cy="275" r="30"></circle>
        <circle cx="250" cy="265" r="20"></circle>
        <circle cx="57" cy="270" r="20"></circle>
        <circle cx="215" cy="345" r="36"></circle>
        <circle cx="310" cy="290" r="36"></circle>
        <circle cx="345" cy="195" r="30"></circle>
        <circle cx="321" cy="107" r="25"></circle>
        <circle cx="260" cy="50" r="20"></circle>
        <circle cx="120" cy="330" r="25"></circle>
      </svg>
    </div>
  </div>

  <!-- Hero Content -->
  <div class="hero-content">
    <div class="container">
      <!-- Main Title with Gradient -->
      <h1 class="hero-title">
        <span class="title-line">State manager for any app</span>
      </h1>

      <!-- Description with Gradient -->
      <p class="hero-description">Start simple, grow easy</p>

      <!-- Call-to-Action Buttons -->
      <div class="cta-container">
        <a
          href={resolveBase(`/start/base`)}
          class="cta-button cta-primary"
          aria-label="Get started with Reatom documentation"
        >
          <span>Get Started</span>
          <svg
            class="cta-icon"
            width="20"
            height="20"
            viewBox="0 0 20 20"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M4.16667 10H15.8333M15.8333 10L10.8333 5M15.8333 10L10.8333 15"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </a>

        <a
          href="https://stackblitz.com/github/reatom/reatom/tree/v1001/examples/react-search"
          target="_blank"
          rel="noopener noreferrer"
          class="cta-button cta-secondary"
          aria-label="Try Reatom on StackBlitz"
        >
          <span>Try Now</span>
          <svg
            class="cta-icon"
            width="20"
            height="20"
            viewBox="0 0 20 20"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M10.8333 2.5L3.33333 11.6667H10L9.16667 17.5L16.6667 8.33333H10L10.8333 2.5Z"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </a>
      </div>
    </div>
  
  
  </div>
  <!-- Scroll Indicator -->
  <div class="scroll-indicator">
    <div class="scroll-arrow"></div>
  </div>

</main>

<style>
  /* Hero Section */
  .hero-section {
    position: relative;
    min-height: 100vh;
    min-height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  /* Background Container */
  .background-container {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    mask-image: linear-gradient(to bottom, #000000FF 90%, #00000000);
  }

  /* Logo Shape */
  .logo-shape {
    position: absolute;
    top: 2rem;
    left: -50%;
    width: 200%;
    height: 200%;
    pointer-events: none;
    opacity: 0.02;
    animation: rotate 600s linear infinite;
    transition: opacity 0.3s ease;
  }

  .logo-shape svg {
    width: 100%;
    height: 100%;
  }

  .logo-shape svg circle {
    fill: var(--bg-primary);
    stroke: var(--text-primary);
    transition: fill 0.3s ease, stroke 0.3s ease;
  }

  .logo-shape svg circle:first-child {
    fill: var(--text-primary);
    transition: fill 0.3s ease;
  }

  @keyframes rotate {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }

  /* Hero Content */
  .hero-content {
    position: relative;
    z-index: 10;
    text-align: center;
    padding: 2rem;
    margin-bottom: 10rem;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  /* Hero Title */
  .hero-title {
    font-size: clamp(3rem, 8vw, 6rem);
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: 1.5rem;
    background: var(--accent-primary);
    background-size: 200% 200%;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    /* animation: gradientText 8s ease infinite; */
    filter: url(#glow);
    transition: background 0.3s ease;
  }

  .title-line {
    display: block;
    font-size: 0.7em;
    font-family: monospace;
    line-height: 1.5;
  }

  .title-subtitle {
    display: block;
    font-size: 0.4em;
    font-weight: 500;
    margin-top: 0.5rem;
  }

  @keyframes gradientText {
    0%,
    100% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
  }

  /* Hero Description */
  .hero-description {
    font-size: clamp(1.2rem, 3vw, 1.8rem);
    font-weight: 500;
    margin-bottom: 3rem;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
    background: linear-gradient(
      135deg,
      var(--text-primary) 0%,
      var(--text-secondary) 50%,
      var(--accent-primary) 100%
    );
    background-size: 200% 200%;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    /* animation: gradientText 10s ease infinite; */
    transition: background 0.3s ease;
  }

  /* CTA Container */
  .cta-container {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    align-items: center;
    margin-bottom: 4rem;
    flex-wrap: wrap;
  }

  /* CTA Buttons */
  .cta-button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem 2rem;
    border-radius: 12px;
    font-weight: 600;
    font-size: 1.1rem;
    text-decoration: none;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
    border: 2px solid transparent;
  }

  .cta-button::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      45deg,
      transparent,
      rgba(255, 255, 255, 0.1),
      transparent
    );
    transform: translateX(-100%);
    transition: transform 0.6s ease;
  }

  .cta-button:hover::before {
    transform: translateX(100%);
  }

  .cta-primary {
    background: var(--accent-gradient);
    color: var(--bg-primary);
    box-shadow: 0 8px 32px var(--shadow-color);
    transition:
      all 0.3s ease,
      background 0.3s ease;
  }

  .cta-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 40px var(--shadow-color);
  }

  .cta-secondary {
    background: var(--bg-secondary);
    color: var(--text-primary);
    border-color: var(--border-color);
    backdrop-filter: blur(10px);
    transition:
      all 0.3s ease,
      background 0.3s ease,
      border-color 0.3s ease,
      color 0.3s ease;
  }

  .cta-secondary:hover {
    background: var(--bg-tertiary);
    border-color: var(--border-color);
    transform: translateY(-2px);
    box-shadow: 0 8px 32px var(--shadow-color);
  }

  .cta-icon {
    transition: transform 0.3s ease;
  }

  .cta-button:hover .cta-icon {
    transform: translateX(4px);
  }

  /* Scroll Indicator */
  .scroll-indicator {
    position: absolute;
    top: calc(100vh - 12rem);
    top: calc(100svh - 12rem);
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
  }

  .scroll-arrow {
    width: 24px;
    height: 24px;
    border: 2px solid var(--accent-primary);
    border-top: none;
    border-left: none;
    transform: rotate(45deg);
    animation: bounce 2s infinite;
    transition: border-color 0.3s ease;
  }

  @keyframes bounce {
    0%,
    20%,
    50%,
    80%,
    100% {
      transform: translateY(0) rotate(45deg);
    }
    40% {
      transform: translateY(-10px) rotate(45deg);
    }
    60% {
      transform: translateY(-5px) rotate(45deg);
    }
  }

  /* Light theme specific adjustments */
  html[data-theme='light'] .cta-primary {
    /* color: #fdfdff; */
    font-weight: 700;
  }

  html[data-theme='light'] .logo-shape {
    opacity: 0.05;
  }

  html[data-theme='light'] .hero-title {
    background: var(--accent-primary);
    background-size: 200% 200%;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  html[data-theme='light'] .hero-description {
    background: linear-gradient(
      135deg,
      var(--text-primary) 0%,
      var(--text-secondary) 50%,
      var(--accent-primary) 100%
    );
    background-size: 200% 200%;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  /* Responsive Design */
  @media (max-width: 768px) {
    .hero-content {
      padding: 1rem;
    }

    .cta-container {
      flex-direction: column;
      gap: 1rem;
    }

    .cta-button {
      width: 100%;
      max-width: 300px;
      justify-content: center;
      padding-left: 0;
      padding-right: 0;
    }

    .cta-secondary {
      display: none;
    }

    .logo-shape {
      /* transform: translateX(-50%); */
      top: -50%;
      left: -50%;
    }
  }

  @media (max-width: 480px) {
    .title-subtitle {
      font-size: 0.35em;
    }

    .hero-description {
      margin-bottom: 2rem;
    }
  }

  /* Accessibility */
  @media (prefers-reduced-motion: reduce) {
    * {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }
  }

  /* Focus styles for accessibility */
  .cta-button:focus {
    outline: 2px solid var(--accent-primary);
    outline-offset: 2px;
  }

  /* High contrast mode support */
  @media (prefers-contrast: high) {
    .hero-title,
    .hero-description {
      -webkit-text-fill-color: var(--text-primary);
      background: none;
    }

    .cta-primary {
      background: var(--accent-primary);
      color: var(--bg-primary);
    }

    .cta-secondary {
      background: transparent;
      color: var(--text-primary);
      border-color: var(--text-primary);
    }
  }
</style>

<script>
  // Mouse movement parallax effect
  function initParallax() {
    const shapes = document.querySelectorAll('.logo-shape')

    document.addEventListener('mousemove', (e) => {
      const mouseX = e.clientX / window.innerWidth
      const mouseY = e.clientY / window.innerHeight

      shapes.forEach((shape, index) => {
        const speed = (index + 1) * 0.5
        const x = (mouseX - 0.5) * speed * 20
        const y = (mouseY - 0.5) * speed * 20

        ;(shape as HTMLElement).style.transform = `translate(${x}px, ${y}px)`
      })
    })
  }

  // Initialize hero animations and interactions
  document.addEventListener('DOMContentLoaded', () => {
    initParallax()
  })

  // Performance optimization: Reduce animations on low-end devices
  if (navigator.hardwareConcurrency && navigator.hardwareConcurrency < 4) {
    document.documentElement.style.setProperty('--animation-duration', '0.5s')
  }
</script>
