{
  "name": "@reatom/form",
  "version": "3.3.2",
  "private": false,
  "sideEffects": false,
  "description": "Reatom for form",
  "exports": {
    "types": "./build/index.d.ts",
    "require": "./build/index.js",
    "default": "./build/index.mjs"
  },
  "main": "build/index.js",
  "module": "build/index.mjs",
  "types": "build/index.d.ts",
  "browserslist": [
    "last 1 year"
  ],
  "scripts": {
    "prepublishOnly": "npm run build && npm run test",
    "build": "yoctobundle",
    "test": "vitest run src/*",
    "test:watch": "vitest src/*"
  },
  "dependencies": {
    "@reatom/async": "^3.10.1",
    "@reatom/core": "^3.1.21",
    "@reatom/effects": "^3.6.0",
    "@reatom/hooks": "^3.1.0",
    "@reatom/primitives": "^3.1.0",
    "@reatom/utils": "^3.7.0"
  },
  "author": "artalar",
  "maintainers": [
    {
      "name": "artalar",
      "url": "https://github.com/artalar"
    },
    {
      "name": "Xelson",
      "url": "https://github.com/xelson"
    }
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/artalar/reatom.git"
  },
  "bugs": {
    "url": "https://github.com/artalar/reatom/issues"
  },
  "homepage": "https://www.reatom.dev/package/form",
  "files": [
    "/build",
    "/package.json"
  ],
  "devDependencies": {
    "@standard-schema/spec": "^1.0.0",
    "zod": "^3.24.1"
  }
}
