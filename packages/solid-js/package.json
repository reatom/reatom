{
	"name": "@reatom/solid-js",
	"version": "1000.0.0-alpha.30",
	"publishConfig": {
		"tag": "alpha"
	},
	"description": "Reatom bindings for solid-js",
	"private": false,
	"sideEffects": false,
	"exports": {
		"types": "./build/index.d.ts",
		"require": "./build/index.js",
		"default": "./build/index.mjs"
	},
	"main": "build/index.js",
	"module": "build/index.mjs",
	"types": "build/index.d.ts",
	"browserslist": [
		"last 1 year"
	],
	"scripts": {
		"prepublishOnly": "pnpm run build && pnpm run test",
		"build": "microbundle -f esm,cjs --raw",
		"test": "vitest run src/*",
		"test:watch": "vitest src/*"
	},
	"dependencies": {
		"@reatom/core": "workspace:^",
		"solid-js": "catalog:"
	},
	"author": {
		"name": "artalar",
		"url": "https://github.com/artalar"
	},
	"maintainers": [
		{
			"name": "artalar",
			"url": "https://github.com/artalar"
		}
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+ssh://git@github.com/reatom/reatom.git",
		"directory": "packages/solid-js"
	},
	"bugs": {
		"url": "https://github.com/reatom/reatom/issues"
	},
	"homepage": "https://www.reatom.dev/package/solid-js",
	"keywords": [
		"reactive",
		"reactivity",
		"state-manager",
		"reatom"
	],
	"files": [
		"/build"
	],
	"devDependencies": {
		"@typescript-eslint/eslint-plugin": "catalog:",
		"@typescript-eslint/parser": "catalog:",
		"eslint-plugin-simple-import-sort": "catalog:"
	}
}
