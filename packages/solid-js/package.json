{
	"name": "@reatom/solid-js",
	"type": "module",
	"version": "1000.0.0-alpha.30",
	"publishConfig": {
		"tag": "not-ready"
	},
	"description": "Reatom bindings for solid-js",
	"private": false,
	"sideEffects": false,
	"exports": {
		"types": "./dist/index.d.ts",
		"require": "./dist/index.cjs",
		"default": "./dist/index.js"
	},
	"main": "dist/index.cjs",
	"module": "dist/index.js",
	"types": "dist/index.d.ts",
	"browserslist": [
		"last 1 year"
	],
	"scripts": {
		"prepublishOnly": "pnpm run build && pnpm run test",
		"build": "tsdown",
		"test": "[ -z \"$CI\" ] && [ -z \"$VERCEL\" ] && vitest run --config=vitest.browser.config.ts || echo 'Skipping browser tests in CI environment'",
		"test:watch": "vitest --config=vitest.browser.config.ts"
	},
	"tsdown": {
		"format": ["esm", "cjs"],
		"fixedExtension": false
	},
	"dependencies": {
		"@reatom/core": "workspace:^",
		"solid-js": "catalog:"
	},
	"author": {
		"name": "artalar",
		"url": "https://github.com/artalar"
	},
	"maintainers": [
		{
			"name": "artalar",
			"url": "https://github.com/artalar"
		}
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+ssh://git@github.com/reatom/reatom.git",
		"directory": "packages/solid-js"
	},
	"bugs": {
		"url": "https://github.com/reatom/reatom/issues"
	},
	"homepage": "https://www.reatom.dev/package/solid-js",
	"keywords": [
		"reactive",
		"reactivity",
		"state-manager",
		"reatom"
	],
	"files": [
		"/dist"
	],
	"devDependencies": {
		"@typescript-eslint/eslint-plugin": "catalog:",
		"@typescript-eslint/parser": "catalog:",
		"@vitest/browser-playwright": "catalog:",
		"eslint-plugin-simple-import-sort": "catalog:",
		"tsdown": "catalog:",
		"vite-plugin-solid": "catalog:",
		"vitest": "catalog:"
	}
}
