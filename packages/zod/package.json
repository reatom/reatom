{
  "name": "@reatom/zod",
  "type": "module",
  "version": "1000.0.0-alpha.60",
  "publishConfig": {
    "tag": "alpha"
  },
  "sideEffects": false,
  "description": "Reatom for zod",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./v4": {
      "types": "./dist/v4.d.ts",
      "require": "./dist/v4.cjs",
      "default": "./dist/v4.js"
    }
  },
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "browserslist": [
    "last 1 year"
  ],
  "scripts": {
    "prepublishOnly": "eslint src --fix && prettier src -w && pnpm run test && pnpm run build",
    "build": "tsdown",
    "test": "vitest run src/*",
    "test:watch": "vitest src/*"
  },
  "tsdown": {
    "entry": ["src/index.ts", "src/v4.ts"],
    "format": ["esm", "cjs"],
    "fixedExtension": false
  },
  "dependencies": {
    "@reatom/core": "workspace:^",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "tsdown": "catalog:",
    "vitest": "catalog:"
  },
  "author": "artalar",
  "maintainers": [
    {
      "name": "artalar",
      "url": "https://github.com/artalar"
    },
    {
      "name": "Xelson",
      "url": "https://github.com/xelson"
    }
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/reatom/reatom.git"
  },
  "bugs": {
    "url": "https://github.com/reatom/reatom/issues"
  },
  "homepage": "https://www.reatom.dev/package/zod",
  "keywords": [
    "zod",
    "reactive",
    "reactivity",
    "state-manager",
    "reatom"
  ],
  "files": [
    "/dist"
  ]
}
