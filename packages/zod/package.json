{
  "name": "@reatom/zod",
  "version": "1000.0.0-alpha.60",
  "publishConfig": {
    "tag": "alpha"
  },
  "sideEffects": false,
  "description": "Reatom for zod",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "require": "./build/index.js",
      "default": "./build/index.mjs"
    },
    "./v4": {
      "types": "./build/v4.d.ts",
      "require": "./build/v4.js",
      "default": "./build/v4.mjs"
    }
  },
  "main": "build/index.js",
  "module": "build/index.module.js",
  "types": "build/index.d.ts",
  "browserslist": [
    "last 1 year"
  ],
  "scripts": {
    "prepublishOnly": "eslint src --fix && prettier src -w && pnpm run test && pnpm run build",
    "build": "microbundle -f esm,cjs --raw",
    "test": "vitest run src/*",
    "test:watch": "vitest src/*"
  },
  "dependencies": {
    "@reatom/core": "workspace:^",
    "zod": "^3.25.0"
  },
  "author": "artalar",
  "maintainers": [
    {
      "name": "artalar",
      "url": "https://github.com/artalar"
    },
    {
      "name": "Xelson",
      "url": "https://github.com/xelson"
    }
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/reatom/reatom.git"
  },
  "bugs": {
    "url": "https://github.com/reatom/reatom/issues"
  },
  "homepage": "https://www.reatom.dev/package/zod",
  "keywords": [
    "zod",
    "reactive",
    "reactivity",
    "state-manager",
    "reatom"
  ],
  "files": [
    "/build"
  ]
}
