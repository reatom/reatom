{
  "name": "@reatom/zod",
  "type": "module",
  "version": "1001.0.0",
  "sideEffects": false,
  "description": "Reatom for Zod 4",
  "exports": {
    "types": "./dist/index.d.ts",
    "require": "./dist/index.cjs",
    "default": "./dist/index.js"
  },
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "browserslist": [
    "last 1 year"
  ],
  "scripts": {
    "prepublishOnly": "eslint src --fix && prettier src -w && pnpm run test && pnpm run build",
    "build": "tsdown",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "tsdown": {
    "entry": ["src/index.ts"],
    "format": ["esm", "cjs"],
    "fixedExtension": false
  },
  "dependencies": {
    "@reatom/core": "workspace:^",
    "zod": "catalog:"
  },
  "peerDependencies": {
    "zod": "^4.1.0"
  },
  "devDependencies": {
    "tsdown": "catalog:",
    "vitest": "catalog:"
  },
  "author": "artalar",
  "maintainers": [
    {
      "name": "artalar",
      "url": "https://github.com/artalar"
    },
    {
      "name": "Xelson",
      "url": "https://github.com/xelson"
    }
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/reatom/reatom.git",
    "directory": "packages/zod"
  },
  "bugs": {
    "url": "https://github.com/reatom/reatom/issues"
  },
  "homepage": "https://www.reatom.dev/package/zod",
  "keywords": [
    "zod",
    "reactive",
    "reactivity",
    "state-manager",
    "reatom"
  ],
  "files": [
    "/dist"
  ]
}
