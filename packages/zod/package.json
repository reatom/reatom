{
  "name": "@reatom/zod",
  "version": "1000.0.0-alpha.0",
  "publishConfig": {
    "tag": "alpha"
  },
  "private": true,
  "sideEffects": false,
  "description": "Reatom for zod",
  "exports": {
    "types": "./build/index.d.ts",
    "require": "./build/index.js",
    "default": "./build/index.mjs"
  },
  "main": "build/index.js",
  "module": "build/index.module.js",
  "types": "build/index.d.ts",
  "browserslist": [
    "last 1 year"
  ],
  "scripts": {
    "prepublishOnly": "npm run build && npm run test",
    "build": "yoctobundle",
    "test": "vitest run src/*",
    "test:watch": "vitest src/*"
  },
  "dependencies": {
    "@reatom/core": ">=3.8.0",
    "zod": "^3.23.4"
  },
  "author": "artalar",
  "maintainers": [
    {
      "name": "artalar",
      "url": "https://github.com/artalar"
    }
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/artalar/reatom.git"
  },
  "bugs": {
    "url": "https://github.com/artalar/reatom/issues"
  },
  "homepage": "https://www.reatom.dev/package/zod",
  "keywords": [
    "zod",
    "reactive",
    "reactivity",
    "state-manager",
    "reatom"
  ],
  "files": [
    "/build"
  ]
}
