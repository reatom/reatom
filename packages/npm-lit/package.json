{
  "name": "@reatom/npm-lit",
  "version": "3.1.3",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "description": "Reatom for npm-lit",
  "exports": {
    "types": "./build/index.d.ts",
    "require": "./build/index.js",
    "default": "./build/index.mjs"
  },
  "main": "build/index.js",
  "module": "build/index.mjs",
  "types": "build/index.d.ts",
  "browserslist": [
    "last 1 year"
  ],
  "scripts": {
    "prepublishOnly": "npm run build && npm run test",
    "build": "yoctobundle",
    "test": "vitest run src/*",
    "test:watch": "vitest src/*",
    "demo": "vite demo"
  },
  "dependencies": {
    "@reatom/async": "^3.1.0",
    "@reatom/utils": "^3.1.0",
    "@reatom/framework": "^3.1.0",
    "lit": "^2.6.0",
    "@reatom/core": "^3.1.0"
  },
  "devDependencies": {
    "vite": "^5.0.0"
  },
  "author": "kaifaty",
  "maintainers": [
    {
      "name": "artalar",
      "url": "https://github.com/artalar"
    },
    {
      "name": "kaifaty",
      "url": "https://github.com/kaifaty"
    }
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/artalar/reatom.git"
  },
  "bugs": {
    "url": "https://github.com/artalar/reatom/issues"
  },
  "homepage": "https://www.reatom.dev/package/npm-lit",
  "files": [
    "/build"
  ]
}
