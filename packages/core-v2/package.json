{
  "name": "@reatom/core-v2",
  "version": "3.1.4",
  "private": false,
  "sideEffects": false,
  "description": "Reatom adapter for core-v2",
  "main": "build/index.js",
  "module": "build/index.es.js",
  "types": "build/index.d.ts",
  "browserslist": [
    "last 1 year"
  ],
  "scripts": {
    "prepublishOnly": "pnpm run build && pnpm run build-primitives && pnpm run test",
    "build": "yoctobundle && yoctobundle --cwd primitives",
    "test": "vitest run src/*",
    "test:watch": "vitest src/*"
  },
  "dependencies": {
    "@reatom/core": "workspace:^",
    "@reatom/hooks": "workspace:^"
  },
  "author": "artalar",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/artalar/reatom.git"
  },
  "bugs": {
    "url": "https://github.com/artalar/reatom/issues"
  },
  "homepage": "https://www.reatom.dev/compat/core-v2",
  "files": [
    "/build",
    "/primitives"
  ]
}
