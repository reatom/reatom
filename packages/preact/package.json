{
  "name": "@reatom/preact",
  "version": "1000.0.0-alpha.65",
  "publishConfig": {
    "tag": "alpha"
  },
  "private": false,
  "description": "Reatom adapter for Preact",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "require": "./build/index.js",
      "default": "./build/index.mjs"
    },
    "./auto": {
      "types": "./build/auto.d.ts",
      "require": "./build/auto.js",
      "default": "./build/auto.mjs"
    },
    "./signal": {
      "types": "./build/signal.d.ts",
      "require": "./build/signal.js",
      "default": "./build/signal.mjs"
    }
  },
  "main": "build/index.js",
  "module": "build/index.mjs",
  "types": "build/index.d.ts",
  "browserslist": [
    "last 1 year"
  ],
  "minify": {
    "mangle": false
  },
  "scripts": {
    "prepublishOnly": "pnpm run build && pnpm run test",
    "build": "microbundle -f esm,cjs --raw",
    "test": "pnpm run test:unit && pnpm run test:browser",
    "test:unit": "vitest run",
    "test:browser": "[ -z \"$CI\" ] && [ -z \"$VERCEL\" ] && vitest run --config=vitest.browser.config.ts || echo 'Skipping browser tests in CI environment'",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@preact/signals": "catalog:",
    "@preact/signals-core": "catalog:",
    "@reatom/core": "workspace:^",
    "preact": "catalog:"
  },
  "peerDependenciesMeta": {
    "@preact/signals": {
      "optional": true
    },
    "@preact/signals-core": {
      "optional": true
    }
  },
  "author": "artalar",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/reatom/reatom.git"
  },
  "bugs": {
    "url": "https://github.com/reatom/reatom/issues"
  },
  "homepage": "https://www.reatom.dev/package/preact",
  "files": [
    "/build"
  ],
  "devDependencies": {
    "@preact/preset-vite": "catalog:",
    "@preact/signals": "catalog:",
    "@preact/signals-core": "catalog:",
    "preact": "catalog:",
    "@vitest/browser-playwright": "catalog:"
  }
}
