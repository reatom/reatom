{
  "name": "@reatom/preact",
  "type": "module",
  "version": "1000.0.0",
  "private": false,
  "description": "Reatom adapter for Preact",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./auto": {
      "types": "./dist/auto.d.ts",
      "require": "./dist/auto.cjs",
      "default": "./dist/auto.js"
    },
    "./signal": {
      "types": "./dist/signal.d.ts",
      "require": "./dist/signal.cjs",
      "default": "./dist/signal.js"
    }
  },
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "browserslist": [
    "last 1 year"
  ],
  "scripts": {
    "prepublishOnly": "pnpm run build && pnpm run test",
    "build": "tsdown",
    "test": "pnpm run test:unit && pnpm run test:browser",
    "test:unit": "vitest run",
    "test:browser": "[ -z \"$CI\" ] && [ -z \"$VERCEL\" ] && vitest run --config=vitest.browser.config.ts || echo 'Skipping browser tests in CI environment'",
    "test:watch": "vitest"
  },
  "tsdown": {
    "entry": ["src/index.ts", "src/auto.ts", "src/signal.ts"],
    "format": ["esm", "cjs"],
    "fixedExtension": false
  },
  "peerDependencies": {
    "@preact/signals": "catalog:",
    "@preact/signals-core": "catalog:",
    "@reatom/core": "workspace:^",
    "preact": "catalog:"
  },
  "peerDependenciesMeta": {
    "@preact/signals": {
      "optional": true
    },
    "@preact/signals-core": {
      "optional": true
    }
  },
  "author": "artalar",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/reatom/reatom.git"
  },
  "bugs": {
    "url": "https://github.com/reatom/reatom/issues"
  },
  "homepage": "https://www.reatom.dev/package/preact",
  "files": [
    "/dist"
  ],
  "devDependencies": {
    "@preact/preset-vite": "catalog:",
    "@preact/signals": "catalog:",
    "@preact/signals-core": "catalog:",
    "@vitest/browser-playwright": "catalog:",
    "preact": "catalog:",
    "tsdown": "catalog:",
    "vitest": "catalog:"
  }
}
