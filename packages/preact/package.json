{
  "name": "@reatom/preact",
  "version": "1000.0.0-alpha.3",
  "publishConfig": {
    "tag": "alpha"
  },
  "description": "Reatom adapter for React",
  "exports": {
    "types": "./build/index.d.ts",
    "require": "./build/index.js",
    "default": "./build/index.mjs"
  },
  "main": "build/index.js",
  "module": "build/index.mjs",
  "types": "build/index.d.ts",
  "browserslist": [
    "last 1 year"
  ],
  "scripts": {
    "prepublishOnly": "pnpm run build && pnpm run test",
    "build": "yoctobundle",
    "test": "vitest run src/*",
    "test:watch": "vitest src/*"
  },
  "peerDependencies": {
    "@reatom/core": "workspace:alpha",
    "preact": "^10.0.0"
  },
  "author": "artalar",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/reatom/reatom.git"
  },
  "bugs": {
    "url": "https://github.com/reatom/reatom/issues"
  },
  "homepage": "https://www.reatom.dev/package/preact",
  "files": [
    "/build"
  ],
  "devDependencies": {
    "@preact/preset-vite": "^2.10.1"
  }
}
