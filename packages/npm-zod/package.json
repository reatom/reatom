{
  "name": "@reatom/npm-zod",
  "version": "3.11.0",
  "private": false,
  "sideEffects": false,
  "description": "Reatom for npm-zod",
  "source": "src/index.ts",
  "exports": {
    "types": "./build/index.d.ts",
    "require": "./build/index.js",
    "default": "./build/index.mjs"
  },
  "main": "build/index.js",
  "module": "build/index.module.js",
  "types": "build/index.d.ts",
  "browserslist": [
    "last 1 year"
  ],
  "minify": {
    "mangle": false
  },
  "scripts": {
    "prepublishOnly": "pnpm run build && pnpm run test",
    "build": "microbundle",
    "test": "vitest run src/* --typecheck",
    "test:watch": "vitest src/* --typecheck"
  },
  "dependencies": {
    "@reatom/core": "workspace:^",
    "@reatom/effects": "workspace:^",
    "@reatom/primitives": "workspace:^",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@reatom/lens": "workspace:^",
    "@reatom/testing": "workspace:^"
  },
  "author": "artalar",
  "maintainers": [
    {
      "name": "artalar",
      "url": "https://github.com/artalar"
    }
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/artalar/reatom.git"
  },
  "bugs": {
    "url": "https://github.com/artalar/reatom/issues"
  },
  "homepage": "https://www.reatom.dev/package/npm-zod",
  "keywords": [
    "npm-zod",
    "reactive",
    "reactivity",
    "state-manager",
    "reatom"
  ],
  "files": [
    "/build",
    "/package.json"
  ]
}
