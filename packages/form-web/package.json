{
  "name": "@reatom/form-web",
  "version": "3.2.2",
  "private": false,
  "sideEffects": false,
  "description": "Reatom for form-web",
  "exports": {
    "types": "./build/index.d.ts",
    "require": "./build/index.js",
    "default": "./build/index.mjs"
  },
  "main": "build/index.js",
  "module": "build/index.mjs",
  "types": "build/index.d.ts",
  "browserslist": [
    "last 1 year"
  ],
  "scripts": {
    "prepublishOnly": "npm run build && npm run test",
    "build": "yoctobundle",
    "test": "vitest run src/*",
    "test:watch": "vitest src/*"
  },
  "dependencies": {
    "@reatom/core": "^3.1.0",
    "@reatom/form": "^3.1.0",
    "@reatom/hooks": "^3.1.0",
    "@reatom/primitives": "^3.1.0",
    "@reatom/utils": "^3.1.0"
  },
  "author": "artalar",
  "maintainers": [
    {
      "name": "artalar",
      "url": "https://github.com/artalar"
    }
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/artalar/reatom.git"
  },
  "bugs": {
    "url": "https://github.com/artalar/reatom/issues"
  },
  "homepage": "https://www.reatom.dev/package/form-web",
  "files": ["/build"]
}
