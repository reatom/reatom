{
  "name": "@reatom/form-web",
  "version": "3.2.2",
  "private": false,
  "sideEffects": false,
  "description": "Reatom for form-web",
  "source": "src/index.ts",
  "exports": {
    "types": "./build/index.d.ts",
    "require": "./build/index.js",
    "default": "./build/index.mjs"
  },
  "main": "build/index.js",
  "module": "build/index.mjs",
  "types": "build/index.d.ts",
  "browserslist": [
    "last 1 year"
  ],
  "minify": {
    "mangle": false
  },
  "scripts": {
    "prepublishOnly": "pnpm run build && pnpm run test",
    "build": "echo 'DEPRECATED'",
    "test": "vitest run src/*",
    "test:watch": "vitest src/*",
    "sandbox": "vite"
  },
  "dependencies": {
    "@reatom/core": "workspace:^",
    "@reatom/form": "workspace:^",
    "@reatom/hooks": "workspace:^",
    "@reatom/primitives": "workspace:^",
    "@reatom/utils": "workspace:^"
  },
  "author": "artalar",
  "maintainers": [
    {
      "name": "artalar",
      "url": "https://github.com/artalar"
    }
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/artalar/reatom.git"
  },
  "bugs": {
    "url": "https://github.com/artalar/reatom/issues"
  },
  "homepage": "https://www.reatom.dev/package/form-web",
  "files": [
    "/build",
    "/package.json"
  ]
}
