{
  "name": "@reatom/testing",
  "version": "3.4.9",
  "private": false,
  "sideEffects": false,
  "description": "Reatom testing package",
  "source": "src/index.ts",
  "exports": {
    "types": "./build/index.d.ts",
    "require": "./build/index.js",
    "default": "./build/index.mjs"
  },
  "main": "build/index.js",
  "module": "build/index.mjs",
  "types": "build/index.d.ts",
  "browserslist": [
    "last 1 year"
  ],
  "minify": {
    "mangle": false
  },
  "scripts": {
    "prepublishOnly": "pnpm run build && pnpm run test",
    "build": "microbundle -f esm,cjs",
    "test": "vitest run src/*",
    "test:watch": "vitest src/*"
  },
  "dependencies": {
    "@reatom/core": "workspace:^",
    "@reatom/persist": "workspace:^"
  },
  "author": "artalar",
  "license": "MIT",
  "files": [
    "/build",
    "/package.json"
  ]
}
