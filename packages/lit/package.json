{
  "name": "@reatom/lit",
  "version": "1000.0.0-alpha.4",
  "publishConfig": {
    "tag": "alpha"
  },
  "sideEffects": false,
  "type": "module",
  "description": "Reatom for lit",
  "exports": {
    "types": "./build/index.d.ts",
    "require": "./build/index.js",
    "default": "./build/index.mjs"
