{
  "name": "@reatom/lit",
  "version": "1000.0.0-alpha.32",
  "publishConfig": {
    "tag": "alpha"
  },
  "sideEffects": false,
  "type": "module",
  "description": "Reatom for lit",
  "exports": {
    "types": "./dist/index.d.ts",
    "require": "./dist/index.cjs",
    "default": "./dist/index.js"
  },
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "browserslist": [
    "last 1 year"
  ],
  "scripts": {
    "prepublishOnly": "pnpm run build && pnpm run test",
    "build": "tsdown",
    "test": "vitest run src/*",
    "test:watch": "vitest src/*",
    "demo": "vite demo"
  },
  "tsdown": {
    "format": ["esm", "cjs"],
    "fixedExtension": false
  },
  "peerDependencies": {
    "lit": "^2.6.0",
    "@reatom/core": "workspace:^"
  },
  "devDependencies": {
    "@vitest/browser-playwright": "catalog:",
    "tsdown": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "author": "kaifaty",
  "maintainers": [
    {
      "name": "artalar",
      "url": "https://github.com/artalar"
    },
    {
      "name": "kaifaty",
      "url": "https://github.com/kaifaty"
    }
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/reatom/reatom.git"
  },
  "bugs": {
    "url": "https://github.com/reatom/reatom/issues"
  },
  "homepage": "https://www.reatom.dev/package/lit",
  "files": [
    "/dist"
  ]
}
