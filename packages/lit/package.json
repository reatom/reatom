{
  "name": "@reatom/lit",
  "version": "1000.1.0",
  "publishConfig": {
    "tag": "alpha"
  },
  "sideEffects": false,
  "type": "module",
  "description": "Reatom for lit",
  "exports": {
    "types": "./build/index.d.ts",
    "require": "./build/index.js",
    "default": "./build/index.mjs"
  },
  "main": "build/index.js",
  "module": "build/index.mjs",
  "types": "build/index.d.ts",
  "browserslist": [
    "last 1 year"
  ],
  "scripts": {
    "prepublishOnly": "pnpm run build && pnpm run test",
    "build": "microbundle -f esm,cjs --raw && pnpm run docs:gen",
    "test": "vitest run src/*",
    "test:watch": "vitest src/*",
    "demo": "vite demo",
    "demo:build": "vite build demo --outDir ../../docs/public/demo/lit-orderbook --emptyOutDir",
    "docs:gen": "node --import tsx build-docs.ts",
    "typecheck:docs": "tsc --noEmit -p tsconfig.docs.json",
    "docs:validate": "node --import tsx scripts/validate-all-docs.ts",
    "docs:validate:file": "node --import tsx scripts/doc-validator-agent.ts"
  },
  "peerDependencies": {
    "@reatom/core": "workspace:^",
    "lit": "^3.0.0"
  },
  "devDependencies": {
    "@vitest/browser-playwright": "catalog:",
    "tsx": "^4.0.0",
    "bybit-api": "^4.4.5",
    "vite": "catalog:"
  },
  "author": "kaifaty",
  "maintainers": [
    {
      "name": "artalar",
      "url": "https://github.com/artalar"
    },
    {
      "name": "kaifaty",
      "url": "https://github.com/kaifaty"
    }
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/reatom/reatom.git"
  },
  "bugs": {
    "url": "https://github.com/reatom/reatom/issues"
  },
  "homepage": "https://www.reatom.dev/package/lit",
  "files": [
    "/build"
  ]
}
