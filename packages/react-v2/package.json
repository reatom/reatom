{
  "name": "@reatom/react-v2",
  "version": "3.1.2",
  "description": "React bindings for @reatom/core-v2",
  "homepage": "https://www.reatom.dev/compat/react-v2",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/artalar/reatom.git"
  },
  "license": "MIT",
  "main": "build/index.js",
  "module": "build/index.es.js",
  "types": "build/index.d.ts",
  "scripts": {
    "prepublishOnly": "pnpm run rebuild",
    "postpublish": "pnpm run clean",
    "build": "pnpm run build-src && pnpm run build-dom-bindings && pnpm run build-native-bindings",
    "build-src": "yoctobundle",
    "build-dom-bindings": "yoctobundle --cwd react-dom-batched-updates",
    "build-native-bindings": "yoctobundle --cwd react-native-batched-updates",
    "clean": "rimraf build/",
    "rebuild": "pnpm run clean && pnpm run build",
    "test": "vitest run tests/*",
    "test:watch": "vitest tests/*",
    "prettify": "prettier --write '**/*.{js,ts,md}'",
    "prettify:watch": "onchange '**/*.{js,ts,md}' -- prettier --write {{changed}}",
    "ts-check": "tsc --noEmit",
    "ts-check:watch": "pnpm run ts-check -- --watch",
    "update": "npx npm-check-updates -u"
  },
  "peerDependencies": {
    "@reatom/core-v2": "workspace:^",
    "react": ">=16.8.0"
  },
  "devDependencies": {
    "@reatom/testing": "workspace:^",
    "@reatom/utils": "workspace:^",
    "@testing-library/react": "^9.5.0",
    "@testing-library/react-hooks": "^8.0.1",
    "@types/react": ">=16.8.0",
    "react": ">=16.8.0",
    "jsdom": "^19.0.0"
  },
  "author": "artalar",
  "maintainers": [
    {
      "name": "artalar"
    },
    {
      "name": "belozer"
    }
  ],
  "readme": "README.md",
  "bugs": {
    "url": "https://github.com/artalar/reatom/issues"
  },
  "keywords": [
    "state",
    "store",
    "flux",
    "atom",
    "reactive",
    "reactivity",
    "state-manager",
    "state manager",
    "reatom",
    "react",
    "hooks"
  ],
  "files": [
    "build",
    "react-dom-batched-updates",
    "react-native-batched-updates"
  ]
}
