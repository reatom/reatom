{
  "name": "@reatom/vue",
  "type": "module",
  "version": "1000.0.0-alpha.31",
  "publishConfig": {
    "tag": "alpha"
  },
  "sideEffects": false,
  "description": "Reatom adapter for Vue",
  "exports": {
    "types": "./dist/index.d.ts",
    "require": "./dist/index.cjs",
    "default": "./dist/index.js"
  },
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "browserslist": [
    "last 1 year"
  ],
  "scripts": {
    "prepublishOnly": "pnpm run build && pnpm run test",
    "build": "tsdown",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "tsdown": {
    "format": ["esm", "cjs"],
    "fixedExtension": false
  },
  "peerDependencies": {
    "@reatom/core": "workspace:^",
    "vue": "^3.5.17"
  },
  "devDependencies": {
    "@vitest/browser-playwright": "catalog:",
    "tsdown": "catalog:",
    "vitest": "catalog:"
  },
  "author": {
    "name": "krulod",
    "url": "https://github.com/krulod"
  },
  "maintainers": [
    {
      "name": "krulod",
      "url": "https://github.com/krulod"
    },
    {
      "name": "artalar",
      "url": "https://github.com/artalar"
    }
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/reatom/reatom.git",
    "directory": "packages/vue"
  },
  "bugs": {
    "url": "https://github.com/reatom/reatom/issues"
  },
  "homepage": "https://www.reatom.dev/package/vue",
  "keywords": [
    "vue",
    "reactive",
    "reactivity",
    "state-manager",
    "reatom"
  ],
  "files": [
    "/dist"
  ]
}
