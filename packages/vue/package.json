{
  "name": "@reatom/vue",
  "version": "1000.0.0-alpha.2",
  "publishConfig": {
    "tag": "alpha"
  },
  "sideEffects": false,
  "description": "Reatom adapter for Vue",
  "exports": {
    "types": "./build/index.d.ts",
    "require": "./build/index.js",
    "default": "./build/index.mjs"
  },
  "main": "build/index.js",
  "module": "build/index.mjs",
  "types": "build/index.d.ts",
  "browserslist": [
    "last 1 year"
  ],
  "scripts": {
    "prepublishOnly": "pnpm run build && pnpm run test",
    "build": "yoctobundle",
    "test": "vitest run src/*",
    "test:watch": "vitest src/*"
  },
  "peerDependencies": {
    "@reatom/core": "workspace:alpha",
    "vue": "^3.5.0"
  },
  "author": {
    "name": "krulod",
    "url": "https://github.com/krulod"
  },
  "maintainers": [
    {
      "name": "krulod",
      "url": "https://github.com/krulod"
    },
    {
      "name": "artalar",
      "url": "https://github.com/artalar"
    }
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/reatom/reatom.git"
  },
  "bugs": {
    "url": "https://github.com/reatom/reatom/issues"
  },
  "homepage": "https://www.reatom.dev/package/vue",
  "keywords": [
    "vue",
    "reactive",
    "reactivity",
    "state-manager",
    "reatom"
  ],
  "files": [
    "/build"
  ]
}
