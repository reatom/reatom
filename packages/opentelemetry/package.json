{
	"name": "@reatom/opentelemetry",
	"type": "module",
	"version": "1000.15.2",
	"description": "OpenTelemetry tracing integration for Reatom",
	"private": false,
	"sideEffects": false,
	"exports": {
		"types": "./dist/index.d.ts",
		"require": "./dist/index.cjs",
		"default": "./dist/index.js"
	},
	"main": "dist/index.cjs",
	"module": "dist/index.js",
	"types": "dist/index.d.ts",
	"browserslist": [
		"last 1 year"
	],
	"scripts": {
		"prepublishOnly": "pnpm run build && pnpm run test",
		"build": "tsdown",
		"test": "vitest run src/*",
		"test:watch": "vitest src/*"
	},
	"tsdown": {
		"format": [
			"esm",
			"cjs"
		],
		"fixedExtension": false
	},
	"peerDependencies": {
		"@reatom/core": "workspace:^"
	},
	"author": {
		"name": "astartsky",
		"url": "https://github.com/astartsky"
	},
	"maintainers": [
		{
			"name": "artalar",
			"url": "https://github.com/artalar"
		},
		{
			"name": "astartsky",
			"url": "https://github.com/astartsky"
		}
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+ssh://git@github.com/reatom/reatom.git",
		"directory": "packages/opentelemetry"
	},
	"bugs": {
		"url": "https://github.com/reatom/reatom/issues"
	},
	"homepage": "https://www.reatom.dev/package/opentelemetry",
	"keywords": [
		"reactive",
		"reactivity",
		"state-manager",
		"reatom"
	],
	"files": [
		"/dist"
	],
	"devDependencies": {
		"@typescript-eslint/eslint-plugin": "^8.28.0",
		"@typescript-eslint/parser": "^8.28.0",
		"eslint-plugin-simple-import-sort": "^12.1.1",
		"tsdown": "catalog:"
	}
}