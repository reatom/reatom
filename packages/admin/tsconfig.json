{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "declarationMap": true,
    "jsx": "preserve",
    "jsxImportSource": "@reatom/jsx",
    "jsxFactory": "h",
    "jsxFragmentFactory": "hf",
    "types": ["@vitest/browser-playwright"],
    "paths": {
      "test": ["./src/test.ts"],
      "@reatom/jsx/jsx-runtime": ["../jsx/src/index.ts"],
      "@reatom/jsx/jsx-dev-runtime": ["../jsx/src/index.ts"]
    }
  },
  "include": ["src", ".storybook/**/*"]
}
