{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "declarationMap": true,
    "jsx": "preserve",
    "jsxImportSource": "@reatom/jsx",
    "jsxFactory": "h",
    "jsxFragmentFactory": "hf",
    "types": ["@vitest/browser-playwright"],
    "paths": {
      "test": ["./src/test.ts"],
      "@reatom/core": ["../core/build/index.d.ts"],
      "@reatom/jsx": ["../jsx/build/index.d.ts"],
      "@reatom/jsx/jsx-runtime": ["../jsx/build/index.d.ts"],
      "@reatom/jsx/jsx-dev-runtime": ["../jsx/build/index.d.ts"]
    }
  },
  "include": ["src", ".storybook/**/*"]
}
