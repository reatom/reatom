{
  "name": "@reatom/admin",
  "type": "module",
  "version": "1000.15.1",
  "description": "Admin dashboard for Reatom tracing — debugger & remote log viewer",
  "private": false,
  "sideEffects": false,
  "exports": {
    "types": "./dist/index.d.ts",
    "require": "./dist/index.cjs",
    "default": "./dist/index.js"
  },
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "browserslist": [
    "last 1 year"
  ],
  "scripts": {
    "prepublishOnly": "pnpm run build && pnpm run test",
    "build": "tsdown",
    "setup:chromium": "pnpm exec playwright install chromium",
    "test": "pnpm test:unit && pnpm test:stories",
    "test:unit": "vitest run --project=@reatom/admin",
    "test:stories": "vitest run --project=storybook",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "msw": {
    "workerDirectory": "public"
  },
  "tsdown": {
    "format": [
      "esm",
      "cjs"
    ],
    "fixedExtension": false
  },
  "dependencies": {
    "@reatom/core": "workspace:^",
    "@reatom/jsx": "workspace:^"
  },
  "author": {
    "name": "artalar",
    "url": "https://github.com/artalar"
  },
  "maintainers": [
    {
      "name": "artalar",
      "url": "https://github.com/artalar"
    }
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/reatom/reatom.git",
    "directory": "packages/admin"
  },
  "bugs": {
    "url": "https://github.com/reatom/reatom/issues"
  },
  "homepage": "https://www.reatom.dev/package/admin",
  "keywords": [
    "reactive",
    "reactivity",
    "state-manager",
    "reatom",
    "devtools",
    "debugger",
    "admin",
    "tracing",
    "logging"
  ],
  "files": [
    "/dist"
  ],
  "devDependencies": {
    "@storybook/addon-vitest": "^10.4.0",
    "@storybook/html": "^10.4.0",
    "@storybook/html-vite": "^10.4.0",
    "@typescript-eslint/eslint-plugin": "catalog:",
    "@typescript-eslint/parser": "catalog:",
    "@vitest/browser": "catalog:",
    "@vitest/browser-playwright": "catalog:",
    "@vitest/ui": "catalog:",
    "eslint-plugin-simple-import-sort": "catalog:",
    "msw": "^2.12.13",
    "msw-storybook-addon": "^2.0.6",
    "storybook": "^10.4.0",
    "tsdown": "catalog:",
    "vitest": "catalog:"
  }
}
