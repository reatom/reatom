{
  "name": "@reatom/eslint-plugin",
  "version": "1000.0.0-alpha.2",
  "publishConfig": {
    "tag": "alpha"
  },
  "private": false,
  "sideEffects": false,
  "description": "Reatom-specific ESLint rules",
  "exports": {
    "types": "./build/index.d.ts",
    "require": "./build/index.js",
    "default": "./build/index.mjs"
  },
  "main": "build/index.js",
  "module": "build/index.mjs",
  "types": "build/index.d.ts",
  "browserslist": [
    "node 16"
  ],
  "scripts": {
    "prepublishOnly": "npm run build && npm run test",
    "build": "yoctobundle",
    "test": "tsx src/index.test.ts",
    "test:watch": "tsx watch src/index.test.ts"
  },
  "author": "pivaszbs",
  "maintainers": [
    {
      "name": "krulod",
      "url": "https://github.com/krulod"
    },
    {
      "name": "artalar",
      "url": "https://github.com/artalar"
    },
    {
      "name": "pivaszbs",
      "url": "https://github.com/pivaszbs"
    },
    {
      "name": "serikovlearning",
      "url": "https://github.com/serikovlearning"
    }
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/artalar/reatom.git"
  },
  "bugs": {
    "url": "https://github.com/artalar/reatom/issues"
  },
  "homepage": "https://www.reatom.dev/package/eslint-plugin",
  "files": [
    "/build"
  ],
  "devDependencies": {
    "@types/eslint": "^9.0.0",
    "@typescript-eslint/rule-tester": "^8.32.0",
    "eslint": "^9.21.0",
    "eslint-plugin-eslint-plugin": "^6.4.0",
    "eslint-plugin-node": "^11.1.0",
    "typescript-eslint": "^8.29.0"
  },
  "dependencies": {
    "@types/estree": "^1.0.6"
  }
}
