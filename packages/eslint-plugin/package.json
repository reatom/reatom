{
  "name": "@reatom/eslint-plugin",
  "type": "module",
  "version": "1000.0.0-alpha.2",
  "publishConfig": {
    "tag": "alpha"
  },
  "private": false,
  "sideEffects": false,
  "description": "Reatom-specific ESLint rules",
  "exports": {
    "types": "./dist/index.d.ts",
    "require": "./dist/index.cjs",
    "default": "./dist/index.js"
  },
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "prepublishOnly": "pnpm run build && pnpm run test",
    "build": "tsdown",
    "test": "tsx src/index.test.ts",
    "test:watch": "tsx watch src/index.test.ts"
  },
  "tsdown": {
    "format": ["esm", "cjs"],
    "fixedExtension": false
  },
  "author": "pivaszbs",
  "maintainers": [
    {
      "name": "krulod",
      "url": "https://github.com/krulod"
    },
    {
      "name": "artalar",
      "url": "https://github.com/artalar"
    },
    {
      "name": "pivaszbs",
      "url": "https://github.com/pivaszbs"
    },
    {
      "name": "serikovlearning",
      "url": "https://github.com/serikovlearning"
    }
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/reatom/reatom.git"
  },
  "bugs": {
    "url": "https://github.com/reatom/reatom/issues"
  },
  "homepage": "https://www.reatom.dev/package/eslint-plugin",
  "files": [
    "/dist"
  ],
  "devDependencies": {
    "@eslint/js": "catalog:",
    "@types/eslint": "catalog:",
    "@typescript-eslint/rule-tester": "catalog:",
    "eslint": "catalog:",
    "tsdown": "catalog:",
    "typescript-eslint": "catalog:"
  }
}
