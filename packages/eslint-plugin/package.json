{
  "name": "@reatom/eslint-plugin",
  "version": "3.8.0",
  "private": false,
  "sideEffects": false,
  "description": "Reatom-specific ESLint rules",
  "source": "src/index.ts",
  "exports": {
    "types": "./build/index.d.ts",
    "require": "./build/index.js",
    "default": "./build/index.mjs"
  },
  "main": "build/index.js",
  "module": "build/index.mjs",
  "types": "build/index.d.ts",
  "browserslist": [
    "node 16"
  ],
  "minify": {
    "mangle": false
  },
  "scripts": {
    "prepublishOnly": "pnpm run build && pnpm run test",
    "build": "microbundle -f esm,cjs",
    "test": "ts-node src/index.test.ts",
    "test:watch": "tsx watch src/index.test.ts",
    "sandbox": "vite"
  },
  "publishConfig": {
    "tag": "experimental"
  },
  "author": "pivaszbs",
  "maintainers": [
    {
      "name": "artalar",
      "url": "https://github.com/artalar"
    }
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/artalar/reatom.git"
  },
  "bugs": {
    "url": "https://github.com/artalar/reatom/issues"
  },
  "homepage": "https://www.reatom.dev/package/eslint-plugin",
  "files": [
    "/build",
    "/package.json"
  ],
  "devDependencies": {
    "@types/eslint": "catalog:",
    "eslint": "catalog:"
  },
  "peerDependencies": {
    "eslint": "^8.0.0 || ^9.0.0"
  },
  "dependencies": {
    "@types/estree": "^1.0.6"
  }
}
