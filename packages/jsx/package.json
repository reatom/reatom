{
  "name": "@reatom/jsx",
  "type": "module",
  "version": "1001.1.0",
  "sideEffects": false,
  "description": "Reatom for jsx",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./jsx-runtime": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./jsx-dev-runtime": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "browserslist": [
    "last 1 year"
  ],
  "scripts": {
    "prepublishOnly": "pnpm run build && pnpm run test",
    "build": "tsdown",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "tsdown": {
    "copy": ["src/jsx.d.ts"],
    "format": ["esm", "cjs"],
    "fixedExtension": false
  },
  "peerDependencies": {
    "@reatom/core": "workspace:^"
  },
  "dependencies": {
    "csstype": "catalog:"
  },
  "devDependencies": {
    "@vitest/browser-playwright": "catalog:",
    "playwright": "catalog:",
    "tsdown": "catalog:",
    "vitest": "catalog:"
  },
  "author": "artalar",
  "maintainers": [
    {
      "name": "artalar",
      "url": "https://github.com/artalar"
    },
    {
      "name": "krulod",
      "url": "https://github.com/krulod"
    }
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/reatom/reatom.git",
    "directory": "packages/jsx"
  },
  "bugs": {
    "url": "https://github.com/reatom/reatom/issues"
  },
  "homepage": "https://www.reatom.dev/package/jsx",
  "files": [
    "/dist",
    "/jsx-runtime",
    "/jsx-dev-runtime"
  ]
}
