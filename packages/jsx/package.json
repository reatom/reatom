{
  "name": "@reatom/jsx",
  "version": "1000.0.0-alpha.4",
  "publishConfig": {
    "tag": "alpha"
  },
  "sideEffects": false,
  "description": "Reatom for jsx",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "default": "./build/index.mjs"
    },
    "./jsx-runtime": {
      "types": "./build/index.d.ts",
      "default": "./build/index.mjs"
    },
    "./jsx-dev-runtime": {
      "types": "./build/index.d.ts",
      "default": "./build/index.mjs"
    }
  },
  "main": "build/index.js",
  "module": "build/index.mjs",
  "types": "build/index.d.ts",
  "browserslist": [
    "last 1 year"
  ],
  "scripts": {
    "prepublishOnly": "pnpm run build",
    "build": "yoctobundle && cp src/jsx.d.ts build/ && cp -r build jsx-runtime/ && cp -r build jsx-dev-runtime/",
    "test": "vitest --watch=false",
    "test:watch": "vitest --watch=true"
  },
  "peerDependencies": {
    "@reatom/core": "workspace:alpha"
  },
  "dependencies": {
    "csstype": "^3.1.2"
  },
  "devDependencies": {
    "@vitest/browser": "^3.0.9",
    "playwright": "^1.51.1"
  },
  "author": "artalar",
  "maintainers": [
    {
      "name": "artalar",
      "url": "https://github.com/artalar"
    },
    {
      "name": "krulod",
      "url": "https://github.com/krulod"
    }
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/reatom/reatom.git"
  },
  "bugs": {
    "url": "https://github.com/reatom/reatom/issues"
  },
  "homepage": "https://www.reatom.dev/package/jsx",
  "files": [
    "/build",
    "/jsx-runtime",
    "/jsx-dev-runtime"
  ]
}
