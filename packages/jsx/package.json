{
  "name": "@reatom/jsx",
  "version": "3.18.1",
  "private": false,
  "sideEffects": false,
  "description": "A JSX runtime for describing dynamic DOM UIs with Reatom.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "require": "./build/index.js",
      "default": "./build/index.mjs"
    },
    "./jsx-runtime": {
      "types": "./build/index.d.ts"
    },
    "./jsx-dev-runtime": {
      "types": "./build/index.d.ts"
    }
  },
  "main": "build/index.js",
  "module": "build/index.mjs",
  "types": "build/index.d.ts",
  "browserslist": [
    "last 1 year"
  ],
  "scripts": {
    "prepublishOnly": "npm run build && npm run test",
    "build": "yoctobundle",
    "test": "vitest run src/*",
    "test:watch": "vitest src/*"
  },
  "dependencies": {
    "@reatom/core": ">=3.6.0",
    "@reatom/primitives": "^3.5.0",
    "@reatom/utils": "^3.5.0",
    "csstype": "^3.1.2"
  },
  "devDependencies": {
    "@vitest/browser": "^3.0.5",
    "playwright": "^1.50.1"
  },
  "author": "artalar",
  "maintainers": [
    {
      "name": "artalar",
      "url": "https://github.com/artalar"
    },
    {
      "name": "krulod",
      "url": "https://github.com/krulod"
    }
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/artalar/reatom.git"
  },
  "bugs": {
    "url": "https://github.com/artalar/reatom/issues"
  },
  "homepage": "https://www.reatom.dev/package/jsx",
  "files": ["/build"]
}
