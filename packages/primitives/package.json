{
  "name": "@reatom/primitives",
  "version": "3.11.0",
  "private": false,
  "sideEffects": false,
  "description": "Reatom for primitives",
  "source": "src/index.ts",
  "exports": {
    "types": "./build/index.d.ts",
    "require": "./build/index.js",
    "default": "./build/index.mjs"
  },
  "main": "build/index.js",
  "module": "build/index.mjs",
  "types": "build/index.d.ts",
  "browserslist": [
    "last 1 year"
  ],
  "minify": {
    "mangle": false
  },
  "scripts": {
    "prepublishOnly": "pnpm run build && pnpm run test",
    "build": "microbundle -f esm,cjs",
    "test": "vitest run src/*",
    "test:watch": "vitest src/*"
  },
  "dependencies": {
    "@reatom/core": "workspace:^",
    "@reatom/utils": "workspace:^"
  },
  "devDependencies": {
    "@reatom/effects": "workspace:^",
    "@reatom/hooks": "workspace:^",
    "@reatom/lens": "workspace:^",
    "@reatom/testing": "workspace:^"
  },
  "author": "artalar",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/artalar/reatom.git"
  },
  "bugs": {
    "url": "https://github.com/artalar/reatom/issues"
  },
  "homepage": "https://www.reatom.dev/package/primitives",
  "files": [
    "/build",
    "/package.json"
  ]
}
