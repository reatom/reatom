{
  "name": "@reatom/devtools",
  "version": "1000.14.1",
  "description": "Reatom developer tools for states and actions inspecting",
  "exports": {
    "types": "./build/index.d.ts",
    "require": "./build/index.js",
    "default": "./build/index.mjs"
  },
  "main": "build/index.js",
  "module": "build/index.mjs",
  "types": "build/index.d.ts",
  "browserslist": [
    "last 1 year"
  ],
  "scripts": {
    "prepublishOnly": "eslint src --fix && prettier src -w && pnpm run test && pnpm run build",
    "build": "microbundle -f esm,cjs --raw",
    "test": "vitest run src/*"
  },
  "dependencies": {
    "@reatom/core": "workspace:",
    "@reatom/jsx": "workspace:",
    "@observablehq/inspector": "catalog:",
    "jsondiffpatch": "catalog:"
  },
  "author": {
    "name": "artalar",
    "url": "https://github.com/artalar"
  },
  "maintainers": [
    {
      "name": "artalar",
      "url": "https://github.com/artalar"
    }
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/reatom/reatom.git",
    "directory": "packages/devtools"
  },
  "bugs": {
    "url": "https://github.com/reatom/reatom/issues"
  },
  "homepage": "https://www.reatom.dev/package/devtools",
  "keywords": [
    "reactive",
    "reactivity",
    "state-manager",
    "reatom"
  ],
  "files": [
    "/build"
  ]
}
