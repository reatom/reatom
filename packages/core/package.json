{
  "name": "@reatom/core",
  "version": "1000.0.0-alpha.26",
  "publishConfig": {
    "tag": "alpha"
  },
  "description": "The ultimate state manager",
  "exports": {
    "types": "./build/index.d.ts",
    "require": "./build/index.js",
    "default": "./build/index.mjs"
  },
  "main": "build/index.js",
  "module": "build/index.mjs",
  "types": "build/index.d.ts",
  "sideEffects": false,
  "browserslist": [
    "last 1 year"
  ],
  "scripts": {
    "prepublishOnly": "tsc -p ./tsconfig.bundle.json && eslint src --fix && prettier src -w && pnpm run build",
    "build": "pnpm run test && pnpm run test:browser && yoctobundle",
    "test": "vitest run",
    "test:browser": "vitest run --config=vitest.browser.config.ts",
    "test:watch": "vitest",
    "deopt": "dexnode deopt.js",
    "bench_dynamic": "tsx bench_dynamic.ts",
    "bench_computed": "tsx bench_computed.ts",
    "bench_computed:mem": "node --expose-gc --import=tsx bench_computed.ts"
  },
  "author": "artalar",
  "contributors": [
    {
      "name": "artalar",
      "url": "https://github.com/artalar"
    }
  ],
  "license": "MIT",
  "readme": "README.md",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/reatom/reatom.git"
  },
  "bugs": {
    "url": "https://github.com/reatom/reatom/issues"
  },
  "homepage": "https://www.reatom.dev/package/core",
  "keywords": [
    "state",
    "store",
    "flux",
    "atom",
    "reactive",
    "reactivity",
    "state-manager",
    "reatom"
  ],
  "files": [
    "/build"
  ],
  "devDependencies": {
    "@artalar/act": "latest",
    "@frp-ts/core": "latest",
    "@ngrx/store": "latest",
    "@preact/signals-core": "latest",
    "@standard-schema/spec": "^1.0.0",
    "@types/node": "latest",
    "@webreflection/signal": "latest",
    "alien-signals": "^1.0.13",
    "cellx": "latest",
    "dexnode": "^1.2.2",
    "effector": "latest",
    "jotai": "^2.12.2",
    "mobx": "latest",
    "mol_wire_lib": "latest",
    "nanostores": "latest",
    "react": "latest",
    "reatomV3": "@reatom/core@3",
    "redux": "latest",
    "reselect": "latest",
    "s-js": "latest",
    "solid-js": "latest",
    "spred": "latest",
    "usignal": "latest",
    "whatsup": "latest",
    "wonka": "latest",
    "zod": "^3.25.17"
  }
}
