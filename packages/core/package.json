{
  "name": "@reatom/core",
  "version": "1000.15.2",
  "description": "The ultimate state manager",
  "exports": {
    "types": "./build/index.d.ts",
    "require": "./build/index.js",
    "default": "./build/index.mjs"
  },
  "main": "build/index.js",
  "module": "build/index.mjs",
  "types": "build/index.d.ts",
  "sideEffects": false,
  "browserslist": [
    "last 1 year"
  ],
  "minify": {
    "mangle": false,
    "format": {
      "beautify": true
    }
  },
  "scripts": {
    "prepublishOnly": "tsc -b tsconfig.build.json && eslint src --fix && prettier src -w && pnpm run test && pnpm run build",
    "build": "microbundle -f esm,cjs --raw",
    "test": "pnpm run test:unit && pnpm run test:browser",
    "test:unit": "vitest run",
    "test:browser": "[ -z \"$CI\" ] && [ -z \"$VERCEL\" ] && vitest run --config=vitest.browser.config.ts || echo 'Skipping browser tests in CI environment'",
    "test:watch": "vitest",
    "deopt": "dexnode deopt.js",
    "bench_dynamic": "tsx bench_dynamic.ts",
    "bench_computed": "tsx bench_computed.ts",
    "bench_computed:mem": "node --expose-gc --import=tsx bench_computed.ts"
  },
  "author": "artalar",
  "contributors": [
    {
      "name": "artalar",
      "url": "https://github.com/artalar"
    }
  ],
  "license": "MIT",
  "readme": "README.md",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/reatom/reatom.git"
  },
  "bugs": {
    "url": "https://github.com/reatom/reatom/issues"
  },
  "homepage": "https://v1000.reatom.dev/",
  "keywords": [
    "state",
    "store",
    "flux",
    "atom",
    "reactive",
    "reactivity",
    "state-manager",
    "reatom"
  ],
  "files": [
    "/build"
  ],
  "dependencies": {
    "@standard-schema/spec": "catalog:"
  },
  "optionalDependencies": {
    "idb-keyval": "*"
  },
  "devDependencies": {
    "@artalar/act": "latest",
    "@frp-ts/core": "latest",
    "@ngrx/store": "latest",
    "@preact/signals-core": "latest",
    "@types/node": "latest",
    "@types/ws": "catalog:",
    "@vitest/browser-playwright": "catalog:",
    "@webreflection/signal": "latest",
    "alien-signals": "catalog:",
    "cellx": "latest",
    "dexnode": "catalog:",
    "effector": "latest",
    "idb-keyval": "^6.2.2",
    "jotai": "catalog:",
    "mobx": "latest",
    "mol_wire_lib": "latest",
    "nanostores": "latest",
    "playwright": "catalog:",
    "react": "catalog:",
    "reatomV3": "npm:@reatom/core@^3.0.0",
    "redux": "latest",
    "reselect": "latest",
    "s-js": "latest",
    "solid-js": "catalog:",
    "spred": "latest",
    "typescript": "catalog:",
    "usignal": "latest",
    "vitest": "catalog:",
    "whatsup": "latest",
    "wonka": "latest",
    "ws": "catalog:",
    "zod": "catalog:"
  }
}
