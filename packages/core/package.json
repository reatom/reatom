{
  "name": "@reatom/core",
  "type": "module",
  "version": "1001.1.0",
  "description": "The ultimate state manager",
  "exports": {
    "types": "./dist/index.d.ts",
    "require": "./dist/index.cjs",
    "default": "./dist/index.js"
  },
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": true,
  "browserslist": [
    "last 1 year"
  ],
  "scripts": {
    "prepublishOnly": "tsc -b tsconfig.build.json && eslint src --fix && prettier src -w && pnpm run test && pnpm run build && pnpm run size",
    "build": "tsdown",
    "test": "pnpm run test:unit && pnpm run test:browser",
    "test:unit": "vitest run",
    "test:browser": "vitest run --config=vitest.browser.config.ts",
    "test:watch": "vitest",
    "size": "size-limit --config .size-limit.json",
    "deopt": "dexnode deopt.js",
    "bench_dynamic": "tsx bench_dynamic.ts",
    "bench_computed": "tsx bench_computed.ts",
    "bench_computed:mem": "node --expose-gc --import=tsx bench_computed.ts"
  },
  "tsdown": {
    "format": {
      "esm": {
        "target": [
          "es2024"
        ]
      },
      "cjs": {
        "target": [
          "node18"
        ]
      }
    },
    "fixedExtension": false,
    "deps": {
      "neverBundle": [
        "idb-keyval"
      ]
    }
  },
  "author": "artalar",
  "contributors": [
    {
      "name": "artalar",
      "url": "https://github.com/artalar"
    }
  ],
  "license": "MIT",
  "readme": "README.md",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/reatom/reatom.git"
  },
  "bugs": {
    "url": "https://github.com/reatom/reatom/issues"
  },
  "homepage": "https://v1001.reatom.dev/",
  "keywords": [
    "state",
    "store",
    "flux",
    "atom",
    "reactive",
    "reactivity",
    "state-manager",
    "reatom"
  ],
  "files": [
    "/dist"
  ],
  "dependencies": {
    "@standard-schema/spec": "catalog:"
  },
  "optionalDependencies": {
    "idb-keyval": "*"
  },
  "devDependencies": {
    "@angular/core": "^21.2.14",
    "@artalar/act": "^3.2.1",
    "@frp-ts/core": "1.0.0-beta.6",
    "@ngrx/store": "^21.1.0",
    "@preact/signals-core": "catalog:",
    "@size-limit/preset-small-lib": "catalog:",
    "@types/node": "catalog:",
    "@types/ws": "catalog:",
    "@vitest/browser": "catalog:",
    "@vitest/browser-playwright": "catalog:",
    "@vitest/expect": "catalog:",
    "@vitest/runner": "catalog:",
    "@webreflection/signal": "^2.1.2",
    "@whatsup/core": "^2.6.0",
    "alien-signals": "^3.2.1",
    "cellx": "^2.3.1",
    "dexnode": "catalog:",
    "effector": "^23.4.4",
    "expect-type": "^1.3.0",
    "idb-keyval": "^6.2.4",
    "jotai": "^2.20.0",
    "mobx": "^6.15.4",
    "mol_wire_lib": "^1.0.1757",
    "nanostores": "^1.3.0",
    "playwright": "catalog:",
    "react": "catalog:",
    "reatomV3": "npm:@reatom/core@^3.0.0",
    "redux": "^5.0.1",
    "reselect": "^5.2.0",
    "s-js": "^0.4.9",
    "size-limit": "catalog:",
    "solid-js": "^1.9.13",
    "spred": "^0.34.0",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "usignal": "^0.10.0",
    "vitest": "catalog:",
    "wonka": "^6.3.6",
    "ws": "catalog:",
    "zod": "catalog:"
  }
}
