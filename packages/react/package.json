{
  "name": "@reatom/react",
  "version": "1000.0.0-alpha.12",
  "publishConfig": {
    "tag": "alpha"
  },
  "private": false,
  "description": "Reatom adapter for React",
  "exports": {
    "types": "./build/index.d.ts",
    "require": "./build/index.js",
    "default": "./build/index.mjs"
  },
  "main": "build/index.js",
  "module": "build/index.mjs",
  "types": "build/index.d.ts",
  "browserslist": [
    "last 1 year"
  ],
  "scripts": {
    "prepublishOnly": "pnpm run build && pnpm run test",
    "build": "yoctobundle",
    "test": "vitest run src/*",
    "test:watch": "vitest src/*"
  },
  "peerDependencies": {
    "@reatom/core": "workspace:alpha",
    "react": ">=18.2.0",
    "react-dom": ">=18.2.0"
  },
  "author": "artalar",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/reatom/reatom.git"
  },
  "bugs": {
    "url": "https://github.com/reatom/reatom/issues"
  },
  "homepage": "https://www.reatom.dev/package/eact",
  "files": [
    "/build"
  ],
  "devDependencies": {
    "@types/react": "^18.2.77",
    "@types/react-dom": "^18.2.7",
    "@vitejs/plugin-react": "^4.4.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}
