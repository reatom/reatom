{
  "name": "@reatom/react",
  "version": "1000.2.2",
  "private": false,
  "description": "Reatom adapter for React",
  "exports": {
    "types": "./build/index.d.ts",
    "require": "./build/index.js",
    "default": "./build/index.mjs"
  },
  "main": "build/index.js",
  "module": "build/index.mjs",
  "types": "build/index.d.ts",
  "browserslist": [
    "last 1 year"
  ],
  "minify": {
    "mangle": false
  },
  "scripts": {
    "prepublishOnly": "pnpm run build && pnpm run test",
    "build": "microbundle -f esm,cjs --raw",
    "test": "vitest run src/*",
    "test:watch": "vitest src/*"
  },
  "peerDependencies": {
    "@reatom/core": "workspace:^",
    "react": ">=16.14.0",
    "react-dom": ">=16.14.0"
  },
  "author": "artalar",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/reatom/reatom.git"
  },
  "bugs": {
    "url": "https://github.com/reatom/reatom/issues"
  },
  "homepage": "https://www.reatom.dev/package/eact",
  "files": [
    "/build"
  ],
  "devDependencies": {
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/use-sync-external-store": "^1.5.0",
    "@vitejs/plugin-react": "catalog:",
    "@vitest/browser-playwright": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "use-sync-external-store": "catalog:",
    "vitest": "catalog:"
  }
}
