{
  "name": "@reatom/react",
  "type": "module",
  "version": "1000.2.2",
  "private": false,
  "description": "Reatom adapter for React",
  "exports": {
    "types": "./dist/index.d.ts",
    "require": "./dist/index.cjs",
    "default": "./dist/index.js"
  },
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "browserslist": [
    "last 1 year"
  ],
  "scripts": {
    "prepublishOnly": "pnpm run build && pnpm run test",
    "build": "tsdown",
    "test": "vitest run src/*",
    "test:watch": "vitest src/*"
  },
  "tsdown": {
    "format": ["esm", "cjs"],
    "fixedExtension": false
  },
  "peerDependencies": {
    "@reatom/core": "workspace:^",
    "react": ">=18.2.0",
    "react-dom": ">=18.2.0"
  },
  "author": "artalar",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/reatom/reatom.git"
  },
  "bugs": {
    "url": "https://github.com/reatom/reatom/issues"
  },
  "homepage": "https://www.reatom.dev/package/eact",
  "files": [
    "/dist"
  ],
  "devDependencies": {
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "@vitest/browser-playwright": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tsdown": "catalog:",
    "vitest": "catalog:"
  }
}
